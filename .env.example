# YT Video Factory — API Keys
# Copy this file to .env and fill in your keys

# Gathos Image API (img_live_* key)
# Get your key at https://gathos.com
GATHOS_IMAGE_API_KEY=

# Gathos TTS API (tts_live_* key — separate from image key)
# Get your key at https://gathos.com
GATHOS_TTS_API_KEY=

# YouTube Direct Upload (free, no third-party)
# Follow the setup guide: docs/YouTube-Direct-Upload-Setup.md
# Get these from Google Cloud Console + OAuth Playground
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
